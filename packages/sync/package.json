    "y-protocols": "^1.0.6",
    "yjs": "catalog:"
  },
  "devDependencies": {
    "@editorzero/errors": "workspace:*",
    "@editorzero/scopes": "workspace:*",
    "@hocuspocus/common": "3.4.4",
    "@types/better-sqlite3": "catalog:",
