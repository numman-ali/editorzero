{
  "name": "@editorzero/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo .tsbuildinfo.test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@editorzero/audit": "workspace:*",
    "@editorzero/auth": "workspace:*",
    "@editorzero/capabilities": "workspace:*",
    "@editorzero/db": "workspace:*",
    "@editorzero/dispatcher": "workspace:*",
    "@editorzero/errors": "workspace:*",
    "@editorzero/ids": "workspace:*",
    "@editorzero/mcp-server": "workspace:*",
    "@editorzero/observability": "workspace:*",
    "@editorzero/principal": "workspace:*",
    "@editorzero/schemas": "workspace:*",
    "@editorzero/scopes": "workspace:*",
    "@editorzero/sync": "workspace:*",
    "@hono/standard-validator": "0.2.2",
    "@standard-community/standard-json": "0.3.5",
    "@standard-community/standard-openapi": "0.2.9",
    "hono": "4.12.14",
    "hono-openapi": "1.3.0",
    "openapi-types": "12.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/json-schema": "7.0.15",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yjs": "catalog:"
  }
}
