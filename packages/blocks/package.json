{
  "name": "@editorzero/blocks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@editorzero/errors": "workspace:*",
    "@editorzero/ids": "workspace:*",
    "@editorzero/schemas": "workspace:*",
    "@editorzero/scopes": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@types/mdast": "^4.0.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
