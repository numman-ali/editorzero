{
  "name": "@editorzero/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "editorzero": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "build:compile": "bun build --compile --outfile ./dist/ez ./src/index.ts",
    "clean": "rm -rf dist *.tsbuildinfo .tsbuildinfo.test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@editorzero/api-client": "workspace:*",
    "@editorzero/capabilities": "workspace:*",
    "citty": "0.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@editorzero/api-server": "workspace:*",
    "@editorzero/auth": "workspace:*",
    "@editorzero/db": "workspace:*",
    "@editorzero/ids": "workspace:*",
    "@editorzero/sync": "workspace:^",
    "@hono/node-server": "^1.19.14",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
